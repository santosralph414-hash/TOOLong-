<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>TOOLong - Educational Material Rentals</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f9fbff;
      margin: 0;
      padding: 0;
    }
    header {
      background-color: #003366;
      color: white;
      padding: 20px;
      text-align: center;
    }
    header img {
      width: 120px;
      display: block;
      margin: 0 auto 10px auto;
    }
    nav {
      background-color: #0055a5;
      padding: 10px;
      text-align: center;
    }
    nav a {
      color: white;
      margin: 0 15px;
      text-decoration: none;
      font-weight: bold;
    }
    nav a:hover {
      text-decoration: underline;
    }
    section {
      padding: 20px;
    }
    h2 {
      color: #003366;
    }
    .team {
      display: flex;
      flex-wrap: wrap;
      gap: 15px;
    }
    .member {
      background: #e6f0ff;
      padding: 10px;
      border-radius: 5px;
      flex: 1 1 200px;
    }
    .catalog {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
    }
    .item {
      border: 1px solid #ccc;
      border-radius: 5px;
      padding: 15px;
      flex: 1 1 200px;
      text-align: center;
      background: #fff;
    }
    .item button {
      background-color: #0055a5;
      color: white;
      border: none;
      padding: 8px;
      cursor: pointer;
      border-radius: 5px;
    }
    .item button:hover {
      background-color: #003366;
    }
    footer {
      background-color: #003366;
      color: white;
      text-align: center;
      padding: 10px;
      margin-top: 20px;
    }
  </style>
</head>
<body>
  <header>
    <!-- Inserted Logo -->
    <img src="TOOLong-logo.png" alt="TOOLong Logo">
    <h1>TOOLong</h1>
    <p>Educational Material Rentals</p>
    <p><em>Tools for Better Learning.</em></p>
  </header>

  <nav>
    <a href="#about">About</a>
    <a href="#vision">Vision & Mission</a>
    <a href="#team">Team</a>
    <a href="#catalog">Catalog</a>
    <a href="#contact">Contact</a>
  </nav>

  <section id="about">
    <h2>About TOOLong</h2>
    <p>TOOLong is a rental marketplace platform that allows students and communities to rent school materials and equipment instead of purchasing them. It promotes accessibility, affordability, and sustainability.</p>
  </section>

  <section id="vision">
    <h2>Vision & Mission</h2>
    <p><strong>Vision:</strong> To become a trusted and accessible community equipment rental platform.</p>
    <p><strong>Mission:</strong> Connect tool owners and renters through a safe, convenient, and reliable digital platform.</p>
  </section>

  <section id="team">
    <h2>Management Team</h2>
    <div class="team">
      <div class="member"><strong>CEO:</strong> Ralph Lauren Santos</div>
      <div class="member"><strong>Operations Manager:</strong> Venice Glenn Umali</div>
      <div class="member"><strong>Finance Manager:</strong> Gian Nicole San Diego</div>
      <div class="member"><strong>Marketing Manager:</strong> Gian Andrei Sampayan</div>
      <div class="member"><strong>IT Support:</strong> Joey Rosal</div>
      <div class="member"><strong>Customer Support:</strong> Mark Jason Salvador & Lester Roculas</div>
    </div>
  </section>

  <section id="catalog">
    <h2>Rental Catalog</h2>
    <div class="catalog">
      <div class="item">
        <h3>Calculator</h3>
        <p>Scientific calculators for exams and projects.</p>
        <button onclick="rentItem('Calculator')">Rent Now</button>
      </div>
      <div class="item">
        <h3>Laptop</h3>
        <p>Affordable laptops for school and work.</p>
        <button onclick="rentItem('Laptop')">Rent Now</button>
      </div>
      <div class="item">
        <h3>Camera</h3>
        <p>High-quality cameras for projects and events.</p>
        <button onclick="rentItem('Camera')">Rent Now</button>
      </div>
      <div class="item">
        <h3>Printer</h3>
        <p>Reliable printers for documents and assignments.</p>
        <button onclick="rentItem('Printer')">Rent Now</button>
      </div>
    </div>
  </section>

  <section id="contact">
    <h2>Contact Us</h2>
    <p>Email: toolongrentals@gmail.com</p>
    <p>Address: Diliman, Quezon City, Philippines</p>
  </section>

  <footer>
    <p>&copy; 2026 TOOLong | Educational Material Rentals</p>
  </footer>

  <script>
    function rentItem(item) {
      alert("You selected to rent: " + item + ". Please proceed to checkout.");
    }
  </script>
</body>
</html>
